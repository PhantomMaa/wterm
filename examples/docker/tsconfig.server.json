{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist",
    "noEmit": false,
    "resolveJsonModule": true,
    "lib": ["es2020"]
  },
  "include": ["server.ts"]
}
